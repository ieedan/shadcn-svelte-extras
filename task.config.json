{
	"$schema": "https://getbizi.dev/schemas/task.config.json",
	"tasks": {
		"dev": {
			"tasks": {
				"registry": {
					"color": "blue",
					"command": "pnpm registry:dev"
				},
				"app": {
					"color": "green",
					"command": "pnpm dev:app"
				},
				"content": {
					"color": "yellow",
					"command": "pnpm velite dev --watch"
				}
			}
		},
		"ci": {
			"tasks": {
				"format": {
					"command": "pnpm format"
				},
				"lint": {
					"command": "pnpm lint",
					"dependsOn": ["ci:format"]
				},
				"check": {
					"command": "pnpm check"
				}
			}
		}
	}
}
